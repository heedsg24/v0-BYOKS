# Substack publication slug (the part before .substack.com).
# Example: if your newsletter lives at byoks.substack.com, set this to "byoks".
# If unset, the signup form runs in demo mode (logs to server console, returns success).
SUBSTACK_PUBLICATION=

# Whop checkout URL the "get your journal" button links to.
# Must be NEXT_PUBLIC_* because it's read in a client component.
NEXT_PUBLIC_WHOP_URL=https://whop.com/checkout/plan_LWUhA5jX2iLa1
